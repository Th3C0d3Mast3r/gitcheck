{
    "AWS_ACCESS_KEY_ID": {
        "description": "AWS Access Key ID",
        "regex": "AKIA[0-9A-Z]{16}",
        "severity": "HIGH"
    },
    "GITHUB_PAT": {
        "description": "GitHub Personal Access Token",
        "regex": "ghp_[a-zA-Z0-9]{36}",
        "severity": "CRITICAL"
    },
    "SLACK_BOT_TOKEN": {
        "description": "Slack Bot Token",
        "regex": "xoxb-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{24}",
        "severity": "HIGH"
    },
    "RSA_PRIVATE_KEY": {
        "description": "RSA Private Key",
        "regex": "-----BEGIN (?:RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----",
        "severity": "CRITICAL"
    },
    "GENERIC_PASSWORD_OR_SECRET": {
        "description": "Generic Password or API Secret Assignment",
        "regex": "(?i)(?:password|secret|api[_-]?key|token)\\s*[:=]\\s*[\"']?([a-zA-Z0-9\\-_]{16,})[\"']?",
        "severity": "MEDIUM"
    },
    "INTERNAL_TOPOGRAPHY_IP": {
        "description": "Hardcoded Internal IP Address (SSRF Risk)",
        "regex": "\\b(?:10\\.|192\\.168\\.)\\d{1,3}\\.\\d{1,3}\\.\\d{1,3}\\b",
        "severity": "MEDIUM"
    },
    "INTERNAL_TOPOGRAPHY_DOMAIN": {
        "description": "Hardcoded Internal Domain (.corp or .local)",
        "regex": "\\b[a-zA-Z0-9-]+\\.(?:corp|local)\\b",
        "severity": "MEDIUM"
    },
    "MOCK_DATA_SSN": {
        "description": "Potential PII (Social Security Number) in mock data",
        "regex": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
        "severity": "HIGH"
    },
    "HARDCODED_UUID": {
        "description": "Hardcoded UUID (Potential Business Logic Bypass)",
        "regex": "\\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b",
        "severity": "LOW"
    }
}
